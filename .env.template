# Copy to .env and override per environment. Do NOT commit .env.
# docker-compose reads this file automatically for ${VAR:-default} lookups.

# Postgres superuser password. Container uses 'tunnels_dev' if unset.
# Set a real secret in any non-throwaway deployment.
DB_PASSWORD=tunnels_dev

# Flask app — comma-separated list of allowed CORS origins. Default
# in app.py covers local Vite dev (http://localhost:3000). Set to the
# public frontend origin when exposing the API off-host.
# CORS_ORIGINS=http://localhost:3000

# Set to any truthy value to keep create_app() from starting the
# background tick thread (used by tests + `flask db upgrade`).
# DISABLE_TICK_LOOP=
